TELEGRAM_BOT_TOKEN=your-bot-token-here
ADMIN_CHAT_ID=your-telegram-user-id
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key        # optional — for voice message transcription
CLAUDE_LOG_COMMANDS=0                  # set to 1 to log all Bash commands to ~/.claude/command-log.txt
PROJECTS_DIR=/home/youruser/Documents  # directory mounted into container for project access
